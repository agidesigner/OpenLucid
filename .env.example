# Database
DATABASE_URL=postgresql+asyncpg://openlucid:openlucid@localhost:5432/openlucid

# Storage
STORAGE_BASE_PATH=./uploads

# Application
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_EXPIRE_HOURS=168

# Email (optional — leave empty to disable password reset emails)
# MAIL_TYPE=resend                   # "resend" or "smtp"; auto-detected if empty
# MAIL_FROM=no-reply@yourdomain.com
# RESEND_API_KEY=re_xxx
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# APP_URL=http://localhost:8000

# AI / MiniMax (legacy — LLM is now configured in the web UI)
AI_API_KEY=
AI_BASE_URL=https://api.minimaxi.com/v1
AI_MODEL=MiniMax-M2.7
