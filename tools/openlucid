def cmd_status(base, token, cookie, args):
    """Print CLI state: server URL, auth mode, pinned context.

    Humans get a two-column aligned table by default. Scripts / agents
    pass ``--json`` to get the stable key-value shape. Names are looked
    up on the server when possible (skipped on any error — ``status``
    must never fail because the server is down)."""
    cfg = _load_config_file()
    ctx = cfg.get("context") or {}
    auth_mode = (
        "bearer token" if cfg.get("token")
        else "session cookie" if cfg.get("cookie")
        else "open (no credentials)"
    )
    mid = ctx.get("merchant_id")
    oid = ctx.get("offer_id")
    m_label = mid
    o_label = oid
    # Best-effort name resolution; failure is silent to keep ``status``
    # useful even when the server is unreachable.
    if mid:
        try:
            m = _request(base, token, cookie, "GET", f"/merchants/{mid}")
            m_label = f"{m.get('name')} ({mid})"
        except SystemExit:
            pass
        except Exception:
            pass
    if oid:
        try:
            o = _request(base, token, cookie, "GET", f"/offers/{oid}")
            o_label = f"{o.get('name')} ({oid})"
        except SystemExit:
            pass
        except Exception:
            pass

    if getattr(args, "json", False):
        print(json.dumps({
            "url": cfg.get("url") or base,
            "auth": auth_mode,
            "pinned_merchant_id": mid,
            "pinned_offer_id": oid,
        }, ensure_ascii=False, indent=2))
        return

    print(f"Server    {cfg.get('url') or base}")
    print(f"Auth      {auth_mode}")
    print(f"Merchant  {m_label or '(none pinned — openlucid use-merchant <name>)'}")
    print(f"Offer     {o_label or '(none pinned — openlucid use-offer <name>)'}")


def _cmd_welcome():
    """Landing page shown when ``openlucid`` is run with no arguments.

    Contextual: different hints when setup hasn't run yet, when the
    server is unreachable, or when nothing is pinned. The goal is that
    a new user can always see *the one command to run next* without
    reading ``--help``."""
    cfg = _load_config_file()
    has_config = bool(cfg.get("url")) and (os.path.isfile(_CONFIG_PATH))
    ctx = cfg.get("context") or {}
    print(f"OpenLucid CLI {CLI_VERSION}\n")
    if not has_config:
        print("First time here. Run setup to point at your OpenLucid server:")
        print("  openlucid setup\n")
        print("Then:")
        print("  openlucid list-merchants")
        print("  openlucid --help     # full command list")
        return
    # Configured — show pinning hints or list-first suggestion
    print(f"Server: {cfg.get('url')}\n")
    if not ctx.get("merchant_id") and not ctx.get("offer_id"):
        print("Pick something to work on (optional — makes later commands shorter):")
        print("  openlucid use-merchant <name>")
        print("  openlucid use-offer <name>\n")
        print("Or just query directly:")
        print("  openlucid list-merchants")
        print("  openlucid list-offers --merchant <name>")
    else:
        print("Currently pinned:")
        if ctx.get("merchant_id"):
            print(f"  merchant  {ctx['merchant_id']}")
        if ctx.get("offer_id"):
            print(f"  offer     {ctx['offer_id']}")
        print("\nCommon next steps:")
        print("  openlucid list-knowledge          # context-driven")
        print("  openlucid kb-qa --question '...'")
        print("  openlucid topic-studio")
        print("  openlucid status                  # full state")
    print("\nAll commands: openlucid --help")


