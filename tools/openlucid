def cmd_create_offer(base, token, cookie, args):
    """Create offer; if --infer-knowledge passed, follow up with the
    AI knowledge-inference pass against the new offer's id (v1.2.0).

    Two-step intentionally: POST /offers stays a pure data write;
    the second call to POST /offers/{id}/infer-knowledge is the
    AI step. If the inference fails the offer creation still
    succeeded — we print a warning but exit 0, matching the v1.1.5
    'minimal write' contract.
    """
    result = _request(base, token, cookie, "POST", "/offers", body=_create_offer_payload(args))
    _out(result)

    if getattr(args, "infer_knowledge", False) and isinstance(result, dict) and result.get("id"):
        offer_id = result["id"]
        try:
            report = _request(
                base, token, cookie, "POST",
                f"/offers/{offer_id}/infer-knowledge",
                body={},
            )
            print("--- inference report ---", file=sys.stderr)
            _out(report)
        except Exception as e:
            print(
                f"Warning: offer {offer_id} created, but knowledge inference failed: {e}",
                file=sys.stderr,
            )
    return result


