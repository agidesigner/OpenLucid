#!/usr/bin/env python3
"""
OpenLucid CLI — query and operate your marketing data from the command line.

Talks to the OpenLucid REST API over HTTP. Zero project dependencies required
(uses only Python standard library).

Configuration priority: --url flag > env vars > ~/.openlucid.json > defaults

Environment variables:
    OPENLUCID_URL     Base URL  (default: http://localhost)
    OPENLUCID_TOKEN   Bearer token for auth (optional)
"""
from __future__ import annotations

import argparse
import json
import os
import re
import sys
import urllib.error
import urllib.parse
import urllib.request

CLI_VERSION = "0.9.9.3"

_UUID_RE = re.compile(r"^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$", re.I)


def _is_uuid(s: str | None) -> bool:
    return bool(s and _UUID_RE.match(s))

# ---------------------------------------------------------------------------
# Configuration
# ---------------------------------------------------------------------------

_CONFIG_PATH = os.path.expanduser("~/.openlucid.json")
_DEFAULTS = {"url": "http://localhost", "token": "", "cookie": ""}


def _load_config_file() -> dict:
    if os.path.isfile(_CONFIG_PATH):
        try:
            with open(_CONFIG_PATH) as f:
                return json.load(f)
        except (json.JSONDecodeError, OSError):
            pass
    return {}


def _save_config_file(cfg: dict) -> None:
    with open(_CONFIG_PATH, "w") as f:
        json.dump(cfg, f, indent=2, ensure_ascii=False)


def _resolve_config(cli_url: str | None = None) -> tuple[str, str, str]:
    """Return (base_url, token, cookie) with correct priority."""
    file_cfg = _load_config_file()
    url = (
        cli_url
        or os.environ.get("OPENLUCID_URL")
        or file_cfg.get("url")
        or _DEFAULTS["url"]
    )
    token = os.environ.get("OPENLUCID_TOKEN") or file_cfg.get("token") or ""
    cookie = file_cfg.get("cookie") or ""
    return url.rstrip("/"), token, cookie


# ---------------------------------------------------------------------------
# HTTP helpers
# ---------------------------------------------------------------------------


def _request(base: str, token: str, cookie: str, method: str, path: str,
             params: dict | None = None, body: dict | None = None) -> dict:
    url = f"{base}/api/v1{path}"
    if params:
        qs = {k: v for k, v in params.items() if v is not None}
        if qs:
            url += "?" + urllib.parse.urlencode(qs)

    data = json.dumps(body).encode("utf-8") if body else None
    headers = {"Content-Type": "application/json", "Accept": "application/json"}
    if token:
        headers["Authorization"] = f"Bearer {token}"
    if cookie:
        headers["Cookie"] = f"od_access_token={cookie}"

    req = urllib.request.Request(url, data=data, headers=headers, method=method)
    try:
        with urllib.request.urlopen(req) as resp:
            raw = resp.read()
            return json.loads(raw) if raw else {}
    except urllib.error.HTTPError as exc:
        err_body = exc.read().decode("utf-8", errors="replace")
        try:
            detail = json.loads(err_body)
        except json.JSONDecodeError:
            detail = err_body
        if exc.code == 401:
            print(
                json.dumps({"error": detail, "status": 401,
                            "hint": "Run `openlucid login` first."}, ensure_ascii=False, indent=2),
                file=sys.stderr,
            )
        else:
            print(
                json.dumps({"error": detail, "status": exc.code}, ensure_ascii=False, indent=2),
                file=sys.stderr,
            )
        sys.exit(1)
    except urllib.error.URLError as exc:
        print(
            json.dumps({"error": str(exc.reason), "hint": "Is the OpenLucid server running?"}, ensure_ascii=False, indent=2),
            file=sys.stderr,
        )
        sys.exit(1)


def _request_form(base: str, token: str, cookie: str, method: str, path: str, form: dict) -> dict:
    url = f"{base}/api/v1{path}"
    data = urllib.parse.urlencode(form).encode("utf-8")
    headers = {
        "Content-Type": "application/x-www-form-urlencoded",
        "Accept": "application/json",
    }
    if token:
        headers["Authorization"] = f"Bearer {token}"
    if cookie:
        headers["Cookie"] = f"od_access_token={cookie}"

    req = urllib.request.Request(url, data=data, headers=headers, method=method)
    try:
        with urllib.request.urlopen(req) as resp:
            raw = resp.read()
            return json.loads(raw) if raw else {}
    except urllib.error.HTTPError as exc:
        err_body = exc.read().decode("utf-8", errors="replace")
        try:
            detail = json.loads(err_body)
        except json.JSONDecodeError:
            detail = err_body
        print(json.dumps({"error": detail, "status": exc.code}, ensure_ascii=False, indent=2), file=sys.stderr)
        sys.exit(1)
    except urllib.error.URLError as exc:
        print(
            json.dumps({"error": str(exc.reason), "hint": "Is the OpenLucid server running?"}, ensure_ascii=False, indent=2),
            file=sys.stderr,
        )
        sys.exit(1)


def _out(data):
    print(json.dumps(data, ensure_ascii=False, indent=2))


def _csv_list(raw: str) -> list[str]:
    return [item.strip() for item in (raw or "").split(",") if item.strip()]


# ---------------------------------------------------------------------------
# Name/UUID reference resolution
#
# Humans don't remember UUIDs. Every command that takes a merchant/offer
# reference accepts EITHER a UUID or a (case-insensitive, substring) name
# match. Unambiguous matches resolve silently; ambiguous ones surface the
# candidates and bail. None + exactly-one-item in the list → auto-pick
# (the "only one merchant" shortcut).
# ---------------------------------------------------------------------------


def _resolve_merchant(
    base: str, token: str, cookie: str, ref: str | None,
    *, silent_auto: bool = False,
) -> str | None:
    """Resolve a merchant reference to a UUID. See module-level docstring."""
    if ref and _is_uuid(ref):
        return ref
    resp = _request(base, token, cookie, "GET", "/merchants", {"page_size": 100})
    items = resp.get("items") or []
    if ref:
        needle = ref.strip().lower()
        exact = [m for m in items if (m.get("name") or "").lower() == needle]
        partial = [m for m in items if needle in (m.get("name") or "").lower()]
        match = exact if exact else partial
        if len(match) == 1:
            return match[0]["id"]
        if not match:
            names = [m.get("name") for m in items]
            print(
                f"Error: no merchant matches {ref!r}. Available: {names}",
                file=sys.stderr,
            )
            sys.exit(1)
        lines = [f"  {m.get('name')!r} (UUID: {m.get('id')})" for m in match]
        print(
            f"Error: {ref!r} matches multiple merchants. Pass the UUID:\n"
            + "\n".join(lines),
            file=sys.stderr,
        )
        sys.exit(1)
    # No ref → auto-pick when unambiguous
    if len(items) == 1:
        if not silent_auto:
            print(
                f"(auto-selected merchant: {items[0].get('name')})",
                file=sys.stderr,
            )
        return items[0]["id"]
    return None


def _resolve_offer(
    base: str, token: str, cookie: str, ref: str | None,
    *, merchant_id: str | None = None, silent_auto: bool = False,
) -> str | None:
    if ref and _is_uuid(ref):
        return ref
    # Fall back to the pinned merchant when the caller didn't specify one.
    # This disambiguates names shared across merchants — the common case
    # of "I work on merchant X, want offer Y within X".
    if merchant_id is None:
        merchant_id = _context_get("merchant_id")
    params = {"page_size": 100}
    if merchant_id:
        params["merchant_id"] = merchant_id
    resp = _request(base, token, cookie, "GET", "/offers", params)
    items = resp.get("items") or []
    if ref:
        needle = ref.strip().lower()
        exact = [o for o in items if (o.get("name") or "").lower() == needle]
        partial = [o for o in items if needle in (o.get("name") or "").lower()]
        match = exact if exact else partial
        if len(match) == 1:
            return match[0]["id"]
        if not match:
            names = [o.get("name") for o in items]
            print(f"Error: no offer matches {ref!r}. Available: {names}", file=sys.stderr)
            sys.exit(1)
        # Duplicate names happen in practice (e.g. two "jogg" offers).
        # Print UUIDs so the user can copy one rather than rename.
        lines = [f"  {o.get('name')!r} (UUID: {o.get('id')})" for o in match]
        print(
            f"Error: {ref!r} matches multiple offers. Pass the UUID:\n"
            + "\n".join(lines),
            file=sys.stderr,
        )
        sys.exit(1)
    if len(items) == 1:
        if not silent_auto:
            print(f"(auto-selected offer: {items[0].get('name')})", file=sys.stderr)
        return items[0]["id"]
    return None


def _context_get(key: str) -> str | None:
    cfg = _load_config_file()
    return (cfg.get("context") or {}).get(key)


def _context_set(key: str, value: str | None) -> None:
    cfg = _load_config_file()
    ctx = dict(cfg.get("context") or {})
    if value:
        ctx[key] = value
    else:
        ctx.pop(key, None)
    if ctx:
        cfg["context"] = ctx
    else:
        cfg.pop("context", None)
    _save_config_file(cfg)


def _resolve_merchant_arg(base, token, cookie, args) -> str:
    """Precedence: --merchant-id (UUID) > --merchant (name/UUID) >
    saved context.merchant_id > auto-pick if only one merchant exists.
    Exits with a useful hint when nothing resolves."""
    ref = getattr(args, "merchant_id", None) or getattr(args, "merchant", None)
    if ref:
        mid = _resolve_merchant(base, token, cookie, ref)
        if not mid:
            print(f"Error: cannot resolve merchant {ref!r}", file=sys.stderr)
            sys.exit(1)
        return mid
    saved = _context_get("merchant_id")
    if saved:
        return saved
    mid = _resolve_merchant(base, token, cookie, None)
    if mid:
        return mid
    print(
        "Error: no merchant specified. Options:\n"
        "  --merchant NAME_OR_ID          # one-off\n"
        "  openlucid use-merchant X   # remember for later commands",
        file=sys.stderr,
    )
    sys.exit(1)


def _resolve_offer_arg(base, token, cookie, args) -> str:
    ref = getattr(args, "offer_id", None) or getattr(args, "offer", None)
    if ref:
        oid = _resolve_offer(base, token, cookie, ref)
        if not oid:
            print(f"Error: cannot resolve offer {ref!r}", file=sys.stderr)
            sys.exit(1)
        return oid
    saved = _context_get("offer_id")
    if saved:
        return saved
    oid = _resolve_offer(base, token, cookie, None)
    if oid:
        return oid
    print(
        "Error: no offer specified. Options:\n"
        "  --offer NAME_OR_ID            # one-off\n"
        "  openlucid use-offer X     # remember for later commands",
        file=sys.stderr,
    )
    sys.exit(1)


def _resolve_scope_arg(base, token, cookie, args) -> tuple[str, str]:
    """Precedence: --offer > --merchant > --scope-type+--scope-id
       > context.offer_id > context.merchant_id > auto-pick (offer first,
       then merchant). Returns (scope_type, scope_id) or exits."""
    if getattr(args, "offer", None):
        return "offer", _resolve_offer(base, token, cookie, args.offer) or ""
    if getattr(args, "merchant", None):
        return "merchant", _resolve_merchant(base, token, cookie, args.merchant) or ""
    scope_t = getattr(args, "scope_type", None)
    scope_i = getattr(args, "scope_id", None)
    if scope_t and scope_i:
        return scope_t, scope_i
    if _context_get("offer_id"):
        return "offer", _context_get("offer_id")  # type: ignore[return-value]
    if _context_get("merchant_id"):
        return "merchant", _context_get("merchant_id")  # type: ignore[return-value]
    oid = _resolve_offer(base, token, cookie, None)
    if oid:
        return "offer", oid
    mid = _resolve_merchant(base, token, cookie, None)
    if mid:
        return "merchant", mid
    print(
        "Error: no scope specified. Options:\n"
        "  --offer NAME_OR_ID        # pick an offer directly\n"
        "  --merchant NAME_OR_ID     # pick a merchant directly\n"
        "  use-offer / use-merchant  # remember for later commands",
        file=sys.stderr,
    )
    sys.exit(1)


def _titles_from_suggestions(suggestions: dict, category: str) -> list[str]:
    return [
        item.get("title", "").strip()
        for item in (suggestions or {}).get(category, [])
        if item.get("title", "").strip()
    ]


def _create_offer_payload(
    args,
    description_override: str | None = None,
    inferred_suggestions: dict | None = None,
) -> dict:
    payload = {
        "merchant_id": args.merchant_id,
        "name": args.name,
        "offer_type": args.offer_type,
        "locale": args.locale,
    }
    if args.offer_model:
        payload["offer_model"] = args.offer_model
    description = description_override if description_override is not None else args.description
    if description:
        payload["description"] = description
    if args.positioning:
        payload["positioning"] = args.positioning
    selling_points = _csv_list(args.selling_points)
    audiences = _csv_list(args.audiences)
    scenarios = _csv_list(args.scenarios)
    if not selling_points:
        selling_points = _titles_from_suggestions(inferred_suggestions or {}, "selling_point")
    if not audiences:
        audiences = _titles_from_suggestions(inferred_suggestions or {}, "audience")
    if not scenarios:
        scenarios = _titles_from_suggestions(inferred_suggestions or {}, "scenario")
    if selling_points:
        payload["core_selling_points_json"] = {"points": selling_points}
    if audiences:
        payload["target_audience_json"] = {"items": audiences}
    if scenarios:
        payload["target_scenarios_json"] = {"items": scenarios}
    return payload


def _extract_text_from_url(base: str, token: str, cookie: str, url: str) -> dict:
    return _request_form(base, token, cookie, "POST", "/ai/extract-text", {"url": url})


def _infer_offer_knowledge(base: str, token: str, cookie: str, args, description: str) -> dict | None:
    url = f"{base}/api/v1/ai/infer-offer-knowledge"
    data = json.dumps(
        {
            "name": args.name,
            "offer_type": args.offer_type,
            "description": description,
            "language": args.locale,
        }
    ).encode("utf-8")
    headers = {"Content-Type": "application/json", "Accept": "application/json"}
    if token:
        headers["Authorization"] = f"Bearer {token}"
    if cookie:
        headers["Cookie"] = f"od_access_token={cookie}"
    req = urllib.request.Request(url, data=data, headers=headers, method="POST")
    try:
        with urllib.request.urlopen(req) as resp:
            raw = resp.read()
            return json.loads(raw) if raw else {}
    except (urllib.error.HTTPError, urllib.error.URLError, json.JSONDecodeError):
        return None


def _build_knowledge_batch(offer_id: str, locale: str, suggestions: dict | None) -> dict | None:
    items = []
    for category, raw_items in (suggestions or {}).items():
        for item in raw_items or []:
            title = (item.get("title") or "").strip()
            if not title:
                continue
            items.append(
                {
                    "scope_type": "offer",
                    "scope_id": offer_id,
                    "knowledge_type": item.get("knowledge_type") or category,
                    "title": title,
                    "content_raw": item.get("content_raw") or "",
                    "language": locale,
                }
            )
    if not items:
        return None
    return {
        "scope_type": "offer",
        "scope_id": offer_id,
        "items": items,
    }


