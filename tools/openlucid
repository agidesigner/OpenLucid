def main():
    parser = _build_parser()
    args = parser.parse_args()

    # Bare ``openlucid`` (no command) → contextual welcome page. Better
    # than argparse's terse "COMMAND required" error: users see the one
    # command that matters next, tailored to whether setup has run /
    # something is pinned.
    if not args.command:
        _cmd_welcome()
        return

    base, token, cookie = _resolve_config(cli_url=args.url)
    handler = _DISPATCH.get(args.command)
    if handler is None:
        parser.print_help()
        sys.exit(1)
    handler(base, token, cookie, args)


if __name__ == "__main__":
    main()
