def cmd_update_offer(base, token, cookie, args):
    """PATCH an offer. Mirrors update-knowledge: pass only the fields you
    want to change. ``--clear FIELD`` sets a column to NULL (uses the
    flat MCP-style names: core_selling_points, target_audiences, ...)."""
    payload: dict = {}
    if args.name is not None:
        payload["name"] = args.name
    if args.description is not None:
        payload["description"] = args.description
    if args.positioning is not None:
        payload["positioning"] = args.positioning
    if args.offer_type is not None:
        payload["offer_type"] = args.offer_type
    if args.offer_model is not None:
        payload["offer_model"] = args.offer_model
    if args.locale is not None:
        payload["locale"] = args.locale
    if args.status is not None:
        payload["status"] = args.status
    if args.selling_points is not None:
        items = _csv_list(args.selling_points)
        payload["core_selling_points_json"] = {"points": items} if items else None
    if args.audiences is not None:
        items = _csv_list(args.audiences)
        payload["target_audience_json"] = {"items": items} if items else None
    if args.scenarios is not None:
        items = _csv_list(args.scenarios)
        payload["target_scenarios_json"] = {"items": items} if items else None
    _CLEAR_ALIAS = {
        "core_selling_points": "core_selling_points_json",
        "target_audiences": "target_audience_json",
        "target_scenarios": "target_scenarios_json",
        "objections": "objections_json",
        "proofs": "proofs_json",
    }
    for f in (args.clear or []):
        col = _CLEAR_ALIAS.get(f, f)
        payload[col] = None
    if not payload:
        print("Error: pass at least one field to update, or use --clear FIELD", file=sys.stderr)
        sys.exit(1)
    _out(_request(base, token, cookie, "PATCH", f"/offers/{args.id}", body=payload))


