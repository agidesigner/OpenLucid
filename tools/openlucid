def cmd_add_knowledge(base, token, cookie, args):
    scope_type, scope_id = _resolve_scope_arg(base, token, cookie, args)
    # ``--content-raw`` is the canonical flag (matches list-knowledge
    # output and the REST schema). ``--content`` is the legacy alias —
    # accepted for backwards compat with shell scripts written before
    # v1.1.3 unified the names. content_raw wins when both are passed.
    body_text = (getattr(args, "content_raw", None) or args.content or "") or None
    if args.content and not getattr(args, "content_raw", None):
        print("warn: --content is deprecated, use --content-raw", file=sys.stderr)

    if args.tags:
        tag_list = [t.strip() for t in args.tags.split(",") if t.strip()]
        tags_json = {"general": tag_list} if tag_list else None
    else:
        tags_json = None

    body = {
        "scope_type": scope_type,
        "scope_id": scope_id,
        "title": args.title,
        "content_raw": body_text,
        "knowledge_type": args.type,
        "language": args.language,
        "source_type": args.source_type,
    }
    if args.source_ref:
        body["source_ref"] = args.source_ref
    if tags_json:
        body["tags_json"] = tags_json
    if args.confidence is not None:
        body["confidence"] = max(0.0, min(1.0, args.confidence))
    _out(_request(base, token, cookie, "POST", "/knowledge", body=body))


