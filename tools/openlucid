def _build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="openlucid",
        description="Query and operate your OpenLucid marketing data via REST API.",
        epilog="Config: --url flag > OPENLUCID_URL env > ~/.openlucid.json > http://localhost",
    )
    parser.add_argument("--url", help="Override the server URL")
    parser.add_argument("--version", action="version", version=f"openlucid {CLI_VERSION}")
    # ``required=False`` so the bare ``openlucid`` call reaches main()
    # instead of argparse printing its own terse usage. We then show a
    # friendlier landing page with next-step suggestions tailored to the
    # user's current config (setup run yet? merchant pinned? etc.).
    sub = parser.add_subparsers(dest="command", required=False,
                                metavar="COMMAND",
                                help="Run `openlucid COMMAND --help` for details")

    # -- setup --
    sub.add_parser("setup", help="Interactive first-time setup (URL + auth + verify)")

    # -- version --
    sub.add_parser("version", help="Print CLI version")

    # -- context pinning (use-*, unset-context, status) --
    p = sub.add_parser("use-merchant",
                       help="Pin a merchant as the default for subsequent commands")
    p.add_argument("ref", help="Merchant name or UUID")

    p = sub.add_parser("use-offer",
                       help="Pin an offer as the default for subsequent commands")
    p.add_argument("ref", help="Offer name or UUID")

    sub.add_parser("unset-context",
                   help="Clear the pinned merchant / offer")

    p = sub.add_parser("status",
                       help="Show current CLI config: URL, auth mode, pinned context")
    p.add_argument("--json", action="store_true",
                   help="Emit machine-readable JSON instead of the aligned text view")

    # -- login --
    p = sub.add_parser("login", help="Authenticate and save session to ~/.openlucid.json")
    p.add_argument("--email", help="Account email (or enter interactively)")
    p.add_argument("--password", help="Account password (or enter interactively)")

    # -- list-merchants --
    p = sub.add_parser("list-merchants", help="List all merchants")
    p.add_argument("--page", type=int, default=1)
    p.add_argument("--page-size", type=int, default=20)

    # -- get-merchant --
    p = sub.add_parser("get-merchant", help="Get a merchant by ID")
    p.add_argument("--id", required=True, help="Merchant UUID")

    # -- list-offers --
    p = sub.add_parser("list-offers", help="List offers (products/services)")
    p.add_argument("--merchant", help="Merchant name or UUID (preferred)")
    p.add_argument("--merchant-id", help="Merchant UUID (legacy; --merchant is preferred)")
    p.add_argument("--page", type=int, default=1)
    p.add_argument("--page-size", type=int, default=20)

    # -- get-offer --
    p = sub.add_parser("get-offer", help="Get an offer by ID")
    p.add_argument("--id", required=True, help="Offer UUID")

    # -- update-offer --
    p = sub.add_parser("update-offer", help="Update an offer (only fields passed are changed)")
    p.add_argument("--id", required=True, help="Offer UUID")
    p.add_argument("--name")
    p.add_argument("--description")
    p.add_argument("--positioning")
    p.add_argument("--offer-type", dest="offer_type",
                   choices=["product", "service", "bundle", "solution"])
    p.add_argument("--offer-model", dest="offer_model")
    p.add_argument("--locale")
    p.add_argument("--status")
    p.add_argument("--selling-points", dest="selling_points",
                   help="Comma-separated; replaces existing list")
    p.add_argument("--audiences", help="Comma-separated; replaces existing list")
    p.add_argument("--scenarios", help="Comma-separated; replaces existing list")
    p.add_argument("--clear", action="append", default=None,
                   help="Set a field to NULL (repeatable). Field names: "
                        "description / positioning / core_selling_points / target_audiences / "
                        "target_scenarios / objections / proofs")

    # -- delete-offer --
    p = sub.add_parser("delete-offer", help="Delete an offer by UUID (cascades attachments)")
    p.add_argument("--id", required=True, help="Offer UUID")

    # -- offer-context --
    p = sub.add_parser("offer-context", help="Get full context for an offer")
    p.add_argument("--id", required=True, help="Offer UUID")

    # -- extract-text --
    p = sub.add_parser("extract-text", help="Extract text content from a URL")
    p.add_argument("--url", dest="page_url", required=True, help="Page URL")

    # -- create-offer --
    p = sub.add_parser("create-offer", help="Create a product/service offer")
    p.add_argument("--merchant-id", required=True, help="Merchant UUID")
    p.add_argument("--name", required=True, help="Offer name")
    p.add_argument("--offer-type", default="product", choices=["product", "service", "bundle", "solution"])
    p.add_argument("--offer-model", help="Optional offer model")
    p.add_argument("--description", default="", help="Offer description")
    p.add_argument("--positioning", default="", help="Offer positioning")
    p.add_argument("--selling-points", default="", help="Comma-separated selling points")
