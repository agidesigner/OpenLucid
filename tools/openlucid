# -- Context (sticky merchant / offer) --

def cmd_use_merchant(base, token, cookie, args):
    """Pin a merchant as the default for subsequent commands.

    Accepts a name or UUID. Stored in ``~/.openlucid.json`` under
    ``context.merchant_id`` and overridden by explicit ``--merchant``
    on individual commands."""
    mid = _resolve_merchant(base, token, cookie, args.ref, silent_auto=True)
    if not mid:
        print(f"Error: cannot resolve merchant {args.ref!r}", file=sys.stderr)
        sys.exit(1)
    _context_set("merchant_id", mid)
    # If pinned merchant has exactly one offer AND no offer already pinned,
    # opportunistically pin that too — common flow is "use-merchant X" then
    # immediately run an offer-scoped command.
    if not _context_get("offer_id"):
        resp = _request(base, token, cookie, "GET", "/offers",
                        {"merchant_id": mid, "page_size": 2})
        items = resp.get("items") or []
        if len(items) == 1:
            _context_set("offer_id", items[0]["id"])
            print(
                f"Pinned merchant → {mid}\n"
                f"Also pinned its single offer → {items[0]['id']} ({items[0].get('name')})",
            )
            return
    print(f"Pinned merchant → {mid}")


