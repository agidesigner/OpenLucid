def _build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="openlucid-cli",
        description="Query and operate your OpenLucid marketing data via REST API.",
        epilog="Config: --url flag > OPENLUCID_URL env > ~/.openlucid.json > http://localhost",
    )
    parser.add_argument("--url", help="Override the server URL")
    parser.add_argument("--version", action="version", version=f"openlucid-cli {CLI_VERSION}")
    sub = parser.add_subparsers(dest="command", required=True,
                                metavar="COMMAND",
                                help="Run `openlucid-cli COMMAND --help` for details")

    # -- setup --
    sub.add_parser("setup", help="Interactive first-time setup (URL + auth + verify)")

    # -- version --
    sub.add_parser("version", help="Print CLI version")

    # -- login --
    p = sub.add_parser("login", help="Authenticate and save session to ~/.openlucid.json")
    p.add_argument("--email", help="Account email (or enter interactively)")
    p.add_argument("--password", help="Account password (or enter interactively)")

    # -- list-merchants --
    p = sub.add_parser("list-merchants", help="List all merchants")
    p.add_argument("--page", type=int, default=1)
    p.add_argument("--page-size", type=int, default=20)

    # -- get-merchant --
    p = sub.add_parser("get-merchant", help="Get a merchant by ID")
    p.add_argument("--id", required=True, help="Merchant UUID")

    # -- list-offers --
    p = sub.add_parser("list-offers", help="List offers (products/services)")
    p.add_argument("--merchant-id", help="Filter by merchant UUID")
    p.add_argument("--page", type=int, default=1)
    p.add_argument("--page-size", type=int, default=20)

    # -- get-offer --
    p = sub.add_parser("get-offer", help="Get an offer by ID")
    p.add_argument("--id", required=True, help="Offer UUID")

    # -- offer-context --
    p = sub.add_parser("offer-context", help="Get full context for an offer")
    p.add_argument("--id", required=True, help="Offer UUID")

    # -- extract-text --
    p = sub.add_parser("extract-text", help="Extract text content from a URL")
    p.add_argument("--url", dest="page_url", required=True, help="Page URL")

    # -- create-offer --
    p = sub.add_parser("create-offer", help="Create a product/service offer")
    p.add_argument("--merchant-id", required=True, help="Merchant UUID")
    p.add_argument("--name", required=True, help="Offer name")
    p.add_argument("--offer-type", default="product", choices=["product", "service", "bundle", "solution"])
    p.add_argument("--offer-model", help="Optional offer model")
    p.add_argument("--description", default="", help="Offer description")
    p.add_argument("--positioning", default="", help="Offer positioning")
    p.add_argument("--selling-points", default="", help="Comma-separated selling points")
    p.add_argument("--audiences", default="", help="Comma-separated target audiences")
    p.add_argument("--scenarios", default="", help="Comma-separated target scenarios")
    p.add_argument("--locale", default="zh-CN", help="Locale, default zh-CN")

    # -- create-offer-from-url --
    p = sub.add_parser("create-offer-from-url", help="Extract URL text and create a product/service offer")
    p.add_argument("--merchant-id", required=True, help="Merchant UUID")
    p.add_argument("--name", required=True, help="Offer name")
    p.add_argument("--url", dest="page_url", required=True, help="Page URL to extract")
    p.add_argument("--offer-type", default="product", choices=["product", "service", "bundle", "solution"])
    p.add_argument("--offer-model", help="Optional offer model")
    p.add_argument("--positioning", default="", help="Offer positioning")
    p.add_argument("--selling-points", default="", help="Comma-separated selling points")
