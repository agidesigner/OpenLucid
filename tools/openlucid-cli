def cmd_extract_text(base, token, cookie, args):
    result = _request_form(base, token, cookie, "POST", "/ai/extract-text", {"url": args.page_url})
    _out(result)
    return result


def cmd_create_offer(base, token, cookie, args):
    result = _request(base, token, cookie, "POST", "/offers", body=_create_offer_payload(args))
    _out(result)
    return result


def cmd_create_offer_from_url(base, token, cookie, args):
    extracted = _extract_text_from_url(base, token, cookie, args.page_url)
    inferred = _infer_offer_knowledge(base, token, cookie, args, extracted.get("text", ""))
    result = _request(
        base,
        token,
        cookie,
        "POST",
        "/offers",
        body=_create_offer_payload(
            args,
            description_override=(inferred or {}).get("description") or extracted.get("text", ""),
            inferred_suggestions=(inferred or {}).get("suggestions"),
        ),
    )
    knowledge_batch = None
    batch_body = _build_knowledge_batch(result["id"], args.locale, (inferred or {}).get("suggestions"))
    if batch_body:
        knowledge_batch = _request(base, token, cookie, "POST", "/knowledge/batch", body=batch_body)
    output = {
        "offer": result,
        "extracted": extracted,
        "inferred": inferred,
        "knowledge_batch": knowledge_batch,
    }
    _out(output)
    return output


