# -- Login --

def _do_login(base: str, email: str, password: str) -> tuple[bool, str, str]:
    """Perform login. Returns (success, cookie_or_error, user_email)."""
    url = f"{base}/api/v1/auth/signin"
    data = json.dumps({"email": email, "password": password}).encode("utf-8")
    headers = {"Content-Type": "application/json", "Accept": "application/json"}
    req = urllib.request.Request(url, data=data, headers=headers, method="POST")
    try:
        with urllib.request.urlopen(req) as resp:
            set_cookies = resp.headers.get_all("Set-Cookie") or []
            saved_token = ""
            for sc in set_cookies:
                if "od_access_token=" in sc:
                    saved_token = sc.split("od_access_token=")[1].split(";")[0]
                    break
            if not saved_token:
                return False, "Login succeeded but no cookie received", email
            result = json.loads(resp.read())
            return True, saved_token, result.get("email", email)
    except urllib.error.HTTPError as exc:
        err_body = exc.read().decode("utf-8", errors="replace")
        try:
            detail = json.loads(err_body)
            msg = detail.get("detail", str(detail)) if isinstance(detail, dict) else str(detail)
        except json.JSONDecodeError:
            msg = err_body
        return False, msg, email
    except urllib.error.URLError as exc:
        return False, f"Cannot connect to {base}: {exc.reason}", email


def _prompt_input(prompt: str, default: str = "") -> str:
    suffix = f" [{default}]" if default else ""
    val = input(f"{prompt}{suffix}: ").strip()
    return val or default


def cmd_login(base, token, cookie, args):
    """Authenticate and save session cookie to ~/.openlucid.json."""
    import getpass
    email = args.email or _prompt_input("Email")
    if not email:
        print("Error: email is required.", file=sys.stderr)
        sys.exit(1)
    password = args.password or getpass.getpass("Password: ")

    ok, result, user_email = _do_login(base, email, password)
    if not ok:
        print(f"\n  Login failed: {result}", file=sys.stderr)
        print("\n  Troubleshooting:", file=sys.stderr)
        if "Cannot connect" in result:
            print(f"    - Is the OpenLucid server running at {base}?", file=sys.stderr)
            print(f"    - Try: curl {base}/health", file=sys.stderr)
        else:
            print("    - Check your email and password", file=sys.stderr)
            print("    - If you forgot your password, reset it in the Web UI", file=sys.stderr)
        print(f"    - Server URL: {base}", file=sys.stderr)
        print(f"    - Override with: openlucid-cli --url <URL> login", file=sys.stderr)
        sys.exit(1)

    cfg = _load_config_file()
    cfg["url"] = base
    cfg["cookie"] = result
    _save_config_file(cfg)

    print(f"\n  Logged in as {user_email}")
    print(f"  Config saved to {_CONFIG_PATH}")
    print(f"  Server: {base}")
    print(f"\n  Try: openlucid-cli list-merchants\n")


# -- Setup --

def cmd_setup(base, token, cookie, args):
    """Interactive first-time setup: URL + login + verify connectivity."""
    import getpass
    print("=== OpenLucid CLI Setup ===\n")

    url = _prompt_input("OpenLucid server URL", base)
    url = url.rstrip("/")

    # Verify server is reachable
    print(f"\nChecking {url} ...", end=" ", flush=True)
    try:
        health_req = urllib.request.Request(f"{url}/health", method="GET")
        with urllib.request.urlopen(health_req, timeout=10) as resp:
            resp.read()
        print("OK")
    except Exception as exc:
        print("FAILED")
        print(f"\n  Cannot reach {url}: {exc}", file=sys.stderr)
        print("  Make sure the OpenLucid server is running.", file=sys.stderr)
        print(f"  Try: curl {url}/health\n", file=sys.stderr)
        sys.exit(1)

    # Ask for token or login
    print("\nAuthentication:")
    print("  1) Login with email/password (creates session cookie)")
    print("  2) Use an MCP token (long-lived, from Web UI Settings > MCP > Access Tokens)")
    choice = _prompt_input("Choose [1/2]", "1")

    if choice == "2":
        mcp_token = _prompt_input("MCP Token")
        if not mcp_token:
            print("Error: token is required.", file=sys.stderr)
            sys.exit(1)
        cfg = _load_config_file()
        cfg["url"] = url
        cfg["token"] = mcp_token
        cfg.pop("cookie", None)
        _save_config_file(cfg)
        print(f"\n  Config saved to {_CONFIG_PATH}")
    else:
        email = _prompt_input("Email")
        if not email:
            print("Error: email is required.", file=sys.stderr)
            sys.exit(1)
        password = getpass.getpass("Password: ")

        ok, result, user_email = _do_login(url, email, password)
        if not ok:
            print(f"\n  Login failed: {result}", file=sys.stderr)
            sys.exit(1)
        cfg = _load_config_file()
        cfg["url"] = url
        cfg["cookie"] = result
        _save_config_file(cfg)
        print(f"\n  Logged in as {user_email}")

    # Verify connectivity with an actual API call
    print("\nVerifying API access ...", end=" ", flush=True)
    new_base, new_token, new_cookie = _resolve_config()
    try:
        _request(new_base, new_token, new_cookie, "GET", "/merchants", {"page": "1", "page_size": "1"})
        print("OK")
    except SystemExit:
        print("FAILED")
        print("\n  Authentication may have failed. Try running setup again.", file=sys.stderr)
        sys.exit(1)

    print(f"\n=== Setup complete! ===")
    print(f"  Config: {_CONFIG_PATH}")
    print(f"  Server: {new_base}")
    print(f"\n  Try: openlucid-cli list-merchants\n")


